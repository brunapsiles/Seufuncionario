{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "seufuncionario-expo",
  "main": "worker.js",
  "compatibility_date": "2026-07-14",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*", "/s/*"]
  },
  "ai": {
    "binding": "AI"
  },
  // Resumo semanal por push: toda segunda-feira 12:00 UTC (09:00 BRT).
  "triggers": {
    "crons": ["0 12 * * 1"]
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "seu-funcionario-db",
      "database_id": "dfa94699-fc55-4129-bca1-ec718f5fc048"
    }
  ],
  "vars": {
    "GEMINI_MODEL": "gemini-flash-lite-latest",
    "XAI_MODEL": "grok-4.3"
  }
}
