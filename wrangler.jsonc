{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "seufuncionario-expo",
  "main": "worker.js",
  "compatibility_date": "2026-07-14",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*"]
  },
  "ai": {
    "binding": "AI"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "seu-funcionario-db",
      "database_id": "a16912a1-fcaa-4889-8fcd-63221dcc6b8e"
    }
  ],
  "vars": {
    "GEMINI_MODEL": "gemini-flash-lite-latest",
    "XAI_MODEL": "grok-4.3"
  }
}
