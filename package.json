{
  "name": "seu-funcionario",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "npm test",
    "build": "vite build",
    "preview": "vite preview",
    "test": "npm run test:unit && npm run test:worker",
    "test:unit": "vitest run --config vite.config.js",
    "test:worker": "vitest run --config vitest.worker.config.js",
    "deploy": "npm run build && npm run deploy:cloudflare",
    "deploy:cloudflare": "npx wrangler d1 migrations apply seu-funcionario-db --remote && npx wrangler deploy",
    "db:migrate": "npx wrangler d1 migrations apply seu-funcionario-db --remote"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.3",
    "docx": "^9.7.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.24.0",
    "mammoth": "^1.12.0",
    "pdfjs-dist": "^6.1.200",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "vite": "^8.1.4"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.18.6",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "jsdom": "^29.1.1",
    "vitest": "^4.1.10"
  }
}
